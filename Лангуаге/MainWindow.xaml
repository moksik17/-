<Window x:Class="Лангуаге.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Лангуаге"
        mc:Ignorable="d"
        Title="Лангуаге" Height="600" Width="1000" MinHeight="600" MinWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="6*"/>
        </Grid.RowDefinitions>
        <Rectangle Fill="#FFE7FABF"/>
        <Image HorizontalAlignment="Left"
               Source="/Properties/school_logo.png">
        </Image>
        <TextBlock 
            HorizontalAlignment="Center"
            Text="Школа иностранного языка"
            VerticalAlignment="Center"
            FontSize="36"
            FontWeight="Bold"
            FontFamily="Comic Sans MS">
        </TextBlock>
        <Frame
           ContentRendered="MainFrame_ContentRendered"
            NavigationUIVisibility="Hidden"
            Name="MainFrame"
            Grid.Row="1">
        </Frame>
        <Button
            Name="BackButton"
            HorizontalAlignment="Right"
            Height="40"
            Content="Назад"
            Background="#FF04A0FF"
            Click="BackButton_Click">
        </Button>
    </Grid>
</Window>
